# Backend API origin used server-side (rewrites, server components).
# The browser never talks to this directly — it calls same-origin /api/*,
# which Next.js proxies here so auth cookies stay first-party.
#
# Required in every environment, including production — there is no
# hardcoded fallback host. In production this must point at the real
# Render API URL for your deployment (see ../render.yaml). Also required
# as a build-time variable (not just a runtime one): next.config.ts's
# rewrites read this once when the app is built, so a Vercel project env
# var or the Docker build's API_URL_SCHEME/API_HOST args (see
# apps/web/Dockerfile) must set it before/during the build, not only at
# container start.
API_URL="http://localhost:4000"

# Public marketing-site origin, used for sitemap.xml/robots.txt/OG tags.
# Falls back to http://localhost:3000 if unset — set this to your real
# production domain before deploying, or sitemap.xml/robots.txt will
# advertise localhost URLs.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Onboarding V3 flag. When enabled, /setup renders the streamlined V3 flow
# (Create → Review → Confirm details → Build) instead of the legacy 7-step
# wizard. Defaults OFF — a missing/blank value keeps the legacy wizard.
# Truthy values: 1, true, on, yes. NOTE: this is a NEXT_PUBLIC_* var inlined
# at BUILD time, so changing it requires a rebuild + redeploy (there is no
# runtime toggle). See ../../ONBOARDING_V3_ROLLOUT.md.
# NEXT_PUBLIC_ONBOARDING_V3="true"
